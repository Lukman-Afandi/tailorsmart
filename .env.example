# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TailorFlow

# Database (PostgreSQL production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Auth.js / NextAuth (URL publik app — wajib konsisten di production)
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=TailorFlow <noreply@yourdomain.com>

# Payments — Midtrans Snap (langganan SaaS)
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# "true" / "1" untuk production API & Snap script
MIDTRANS_IS_PRODUCTION=
# Opsional: override harga IDR (default 149000 / 349000)
BILLING_BASIC_AMOUNT_IDR=
BILLING_PROFESSIONAL_AMOUNT_IDR=

XENDIT_WEBHOOK_TOKEN=

# Cron (Vercel / manual curl)
CRON_SECRET=

# Redis cache (Upstash) — opsional
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudinary (logo & foto order)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Super admin JWT (pisahkan dari AUTH_SECRET di production)
PLATFORM_ADMIN_JWT_SECRET=

# Bootstrap super admin sekali (opsional, lalu hapus dari env)
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=
